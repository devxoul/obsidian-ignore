{
  "name": "obsidian-ignore",
  "version": "1.0.0",
  "description": "Hide files matching .obsidianignore (gitignore syntax) from the file explorer, search, and graph.",
  "keywords": [
    "gitignore",
    "obsidian",
    "obsidian-plugin"
  ],
  "license": "MIT",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "bun run esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && bun run esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "test": "bun test"
  },
  "dependencies": {
    "ignore": "^7.0.5"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "^1.13.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^6.0.3"
  }
}
