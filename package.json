{
  "name": "obsidian-ignore",
  "version": "1.0.0",
  "description": "Hide files matching .obsidianignore (gitignore syntax) from the Obsidian UI.",
  "main": "main.js",
  "type": "module",
  "license": "MIT",
  "keywords": ["obsidian", "obsidian-plugin", "gitignore"],
  "scripts": {
    "dev": "bun run esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && bun run esbuild.config.mjs production",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "test": "bun test"
  },
  "dependencies": {
    "ignore": "^7.0.5"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "obsidian": "^1.13.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^6.0.3"
  }
}
